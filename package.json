{
  "name": "vsinkore",
  "displayName": "vsinkore",
  "description": "WYSIWYG Markdown editing for VSCode, powered by the Inkore editor core.",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "inkore",
  "repository": {
    "type": "git",
    "url": "https://github.com/cytia/vsinkore.git"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "customEditors": [
      {
        "viewType": "inkore.editor",
        "displayName": "Inkore Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "prepare": "git config core.hooksPath scripts/git-hooks",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mdit/plugin-katex": "^0.25.2",
    "katex": "^0.16.45",
    "markdown-it": "^14.1.0",
    "orderedmap": "^2.1.1",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-view": "^1.41.8",
    "shiki": "^1.29.2"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
